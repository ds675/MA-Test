{{ 'custom-header.css' | asset_url | stylesheet_tag }}

<custom-header-component
  id="custom-header"
  class="custom-header color-{{ section.settings.color_scheme }}{% if section.settings.enable_sticky %} custom-header--sticky{% endif %}"
  data-section-id="{{ section.id }}"
  data-search-url="{{ routes.predictive_search_url }}"
>
  {%- comment -%} ===== MAIN HEADER ROW ===== {%- endcomment -%}
  <div class="custom-header__main">
    <div class="custom-header__left">
      {%- comment -%} Mobile hamburger {%- endcomment -%}
      <button
        class="custom-header__hamburger"
        type="button"
        aria-label="{{ 'sections.custom_header.menu' | t }}"
        aria-haspopup="dialog"
        on:click="/handleOpenDrawer"
      >
        <img
          src="{{ 'menu-streamline-sharp-material-symbols.svg' | asset_url }}"
          alt=""
          width="28"
          height="28"
          aria-hidden="true"
        >
      </button>

      {%- comment -%} Logo {%- endcomment -%}
      <div class="custom-header__logo">
        <a href="{{ routes.root_url }}" class="custom-header__logo-link" aria-label="{{ shop.name }}">
          <img
            class="custom-header__logo-desktop"
            src="{{ 'shop-logo-2.svg' | asset_url }}"
            alt="{{ shop.name }}"
            width="178"
            height="24"
            loading="eager"
          >
          <img
            class="custom-header__logo-mobile"
            src="{{ 'shop-logo.svg' | asset_url }}"
            alt="{{ shop.name }}"
            width="148"
            height="20"
            loading="eager"
          >
        </a>
      </div>
    </div>

    {%- comment -%} Desktop navigation {%- endcomment -%}
    {%- if section.settings.desktop_menu != blank -%}
      <nav class="custom-header__desktop-nav" aria-label="{{ 'sections.custom_header.desktop_navigation' | t }}">
        {%- for link in linklists[section.settings.desktop_menu].links -%}
          <a href="{{ link.url }}" class="custom-header__desktop-nav-link">
            {{- link.title | escape -}}
          </a>
        {%- endfor -%}
      </nav>
    {%- endif -%}

    {%- comment -%} Desktop search bar {%- endcomment -%}
    <div class="custom-header__search">
      <form class="custom-header__search-form" action="{{ routes.search_url }}" method="get" role="search">
        <input
          ref="searchInput"
          class="custom-header__search-input"
          type="search"
          name="q"
          placeholder="{{ section.settings.search_placeholder | escape }}"
          autocomplete="off"
          on:input="/handleSearchInput"
          aria-label="{{ 'sections.custom_header.open_search' | t }}"
        >
        <button class="custom-header__search-btn" type="submit" aria-label="{{ 'sections.custom_header.open_search' | t }}">
          <img
            src="{{ 'search-streamline-sharp-streamline-material-free.svg' | asset_url }}"
            alt=""
            width="20"
            height="20"
            aria-hidden="true"
          >
        </button>
      </form>
      <div ref="searchResults" class="custom-header__search-results" aria-live="polite"></div>
    </div>

    {%- comment -%} Right actions {%- endcomment -%}
    <div class="custom-header__right">
      {%- comment -%} Mobile search toggle button {%- endcomment -%}
      <button
        class="custom-header__mobile-search-toggle"
        type="button"
        aria-label="{{ 'sections.custom_header.open_search' | t }}"
        on:click="/handleOpenMobileSearch"
      >
        <img
          src="{{ 'search-streamline-sharp-streamline-material-free.svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          aria-hidden="true"
        >
      </button>

      {%- if section.settings.cta_text != blank -%}
        <a
          class="custom-header__cta-link"
          href="{{ section.settings.cta_url | default: '#' }}"
        >
          {{- section.settings.cta_text | escape -}}
        </a>
      {%- endif -%}

      <div class="custom-header__actions">
        {%- comment -%} US Flag {%- endcomment -%}
        <div class="custom-header__flag-icon">
          <img
            src="{{ 'us-united-states-streamline-flagpack.svg' | asset_url }}"
            alt="US"
            width="18"
            height="18"
            loading="lazy"
          >
        </div>

        {%- comment -%} Sign in {%- endcomment -%}
        {%- if shop.customer_accounts_enabled -%}
          <a href="{{ routes.account_url }}" class="custom-header__action" aria-label="{{ 'sections.custom_header.sign_in' | t }}">
            <span class="custom-header__action-icon">
              <img
                src="{{ 'frame-663.svg' | asset_url }}"
                alt=""
                width="28"
                height="28"
                aria-hidden="true"
              >
            </span>
            <span class="custom-header__action-label">{{ 'sections.custom_header.sign_in' | t }}</span>
          </a>
        {%- else -%}
          <a href="{{ routes.account_login_url }}" class="custom-header__action" aria-label="{{ 'sections.custom_header.sign_in' | t }}">
            <span class="custom-header__action-icon">
              <img
                src="{{ 'frame-663.svg' | asset_url }}"
                alt=""
                width="28"
                height="28"
                aria-hidden="true"
              >
            </span>
            <span class="custom-header__action-label">{{ 'sections.custom_header.sign_in' | t }}</span>
          </a>
        {%- endif -%}

        {%- comment -%} Cart {%- endcomment -%}
        <a href="{{ routes.cart_url }}" class="custom-header__action" aria-label="{{ 'sections.custom_header.cart' | t }}">
          <span class="custom-header__action-icon">
            <img
              src="{{ 'shopping-bag-streamline-outlined-material-symbols.svg' | asset_url }}"
              alt=""
              width="28"
              height="28"
              aria-hidden="true"
            >
          </span>
          <span class="custom-header__action-label">{{ 'sections.custom_header.cart' | t }}</span>
        </a>
      </div>
    </div>
  </div>

  {%- comment -%} ===== MOBILE SEARCH STATE ===== {%- endcomment -%}
  <div ref="mobileSearch" class="custom-header__mobile-search" aria-label="{{ 'sections.custom_header.open_search' | t }}">
    <form class="custom-header__mobile-search-form" action="{{ routes.search_url }}" method="get" role="search">
      <input
        ref="mobileSearchInput"
        class="custom-header__mobile-search-input"
        type="search"
        name="q"
        placeholder="{{ section.settings.search_placeholder | escape }}"
        autocomplete="off"
        on:input="/handleMobileSearchInput"
        aria-label="{{ 'sections.custom_header.open_search' | t }}"
      >
      <button class="custom-header__mobile-search-btn" type="submit" aria-label="{{ 'sections.custom_header.open_search' | t }}">
        <img
          src="{{ 'search-streamline-sharp-streamline-material-free.svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          aria-hidden="true"
        >
      </button>
    </form>

    {%- if section.settings.mobile_cta_image != blank -%}
      <a
        class="custom-header__mobile-cta"
        href="{{ section.settings.mobile_cta_url | default: '#' }}"
        aria-label="{{ section.settings.mobile_cta_label | escape }}"
      >
        <img
          src="{{ section.settings.mobile_cta_image | image_url: width: 80 }}"
          alt="{{ section.settings.mobile_cta_label | escape }}"
          width="40"
          height="40"
          loading="lazy"
        >
      </a>
    {%- endif -%}

    <button
      class="custom-header__mobile-search-close"
      type="button"
      aria-label="{{ 'sections.custom_header.close_search' | t }}"
      on:click="/handleCloseMobileSearch"
    >
      <svg viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 1L17 17M1 17L17 1" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <div ref="mobileSearchResults" class="custom-header__mobile-search-results" aria-live="polite"></div>
  </div>

  {%- comment -%} ===== SUB-HEADER ROW (Desktop only) ===== {%- endcomment -%}
  <div class="custom-header__subheader">
    <div class="custom-header__subheader-left">
      <button
        class="custom-header__departments-btn"
        type="button"
        aria-label="{{ 'sections.custom_header.departments' | t }}"
        aria-haspopup="dialog"
        on:click="/handleOpenDrawer"
      >
        <img
          src="{{ 'menu-streamline-sharp-material-symbols.svg' | asset_url }}"
          alt=""
          width="28"
          height="28"
          aria-hidden="true"
        >
      </button>

      {%- if section.settings.sub_menu != blank -%}
        <nav class="custom-header__subheader-nav" aria-label="{{ 'sections.custom_header.departments' | t }}">
          {%- for link in linklists[section.settings.sub_menu].links -%}
            <a href="{{ link.url }}" class="custom-header__subheader-link">
              {{- link.title | escape -}}
            </a>
          {%- endfor -%}
        </nav>
      {%- endif -%}
    </div>

    <div class="custom-header__subheader-center">
      {%- if section.settings.promo_text != blank -%}
        {%- if section.settings.promo_url != blank -%}
          <a href="{{ section.settings.promo_url }}" class="custom-header__promo-text">
            {{- section.settings.promo_text | escape -}}
          </a>
        {%- else -%}
          <span class="custom-header__promo-text">
            {{- section.settings.promo_text | escape -}}
          </span>
        {%- endif -%}
      {%- endif -%}
    </div>

    <div class="custom-header__subheader-right">
      {%- if section.settings.promo_cta_text != blank -%}
        <a
          class="custom-header__promo-cta"
          href="{{ section.settings.promo_cta_url | default: '#' }}"
        >
          {{- section.settings.promo_cta_text | escape -}}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ===== DRAWER ===== {%- endcomment -%}
  <div
    ref="drawerOverlay"
    class="custom-header__drawer-overlay"
    on:click="/handleCloseDrawer"
    aria-hidden="true"
  ></div>

  <div
    ref="drawer"
    class="custom-header__drawer"
    role="dialog"
    aria-modal="true"
    aria-label="{{ 'sections.custom_header.menu' | t }}"
    on:keydown="/handleDrawerKeydown"
  >
    <div class="custom-header__drawer-header">
      <span class="custom-header__drawer-title">{{ 'sections.custom_header.menu' | t }}</span>
      <button
        ref="drawerClose"
        class="custom-header__drawer-close"
        type="button"
        aria-label="{{ 'sections.custom_header.close' | t }}"
        on:click="/handleCloseDrawer"
      >
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6 6L18 18M6 18L18 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <nav class="custom-header__drawer-nav" aria-label="{{ 'sections.custom_header.menu' | t }}">
      {%- if section.settings.desktop_menu != blank -%}
        {%- for link in linklists[section.settings.desktop_menu].links -%}
          <a href="{{ link.url }}" class="custom-header__drawer-link">
            {{- link.title | escape -}}
          </a>
        {%- endfor -%}
      {%- endif -%}

      {%- if section.settings.sub_menu != blank -%}
        <span class="custom-header__drawer-nav-group-title">{{ 'sections.custom_header.departments' | t }}</span>
        {%- for link in linklists[section.settings.sub_menu].links -%}
          <a href="{{ link.url }}" class="custom-header__drawer-link">
            {{- link.title | escape -}}
          </a>
        {%- endfor -%}
      {%- endif -%}
    </nav>
  </div>
</custom-header-component>

<script src="{{ 'custom-header.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% schema %}
{
  "name": "t:names.custom_header",
  "tag": "header",
  "class": "custom-header-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.main_header"
    },
    {
      "type": "link_list",
      "id": "desktop_menu",
      "label": "t:settings.desktop_menu",
      "info": "Used for the desktop nav bar and the mobile slide-out drawer.",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:settings.cta_text",
      "default": "Take Quiz"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:settings.cta_url"
    },
    {
      "type": "header",
      "content": "t:content.search"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "t:settings.search_placeholder",
      "default": "Search products"
    },
    {
      "type": "header",
      "content": "Mobile icon CTA"
    },
    {
      "type": "paragraph",
      "content": "Shown only on mobile, to the right of the search bar."
    },
    {
      "type": "image_picker",
      "id": "mobile_cta_image",
      "label": "Icon image"
    },
    {
      "type": "url",
      "id": "mobile_cta_url",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "mobile_cta_label",
      "label": "Accessibility label",
      "default": "Account"
    },
    {
      "type": "header",
      "content": "t:content.sub_header"
    },
    {
      "type": "link_list",
      "id": "sub_menu",
      "label": "t:settings.sub_menu"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "t:settings.promo_text",
      "default": "$6,073,506,282 awarded in cash! Learn More"
    },
    {
      "type": "url",
      "id": "promo_url",
      "label": "t:settings.promo_url"
    },
    {
      "type": "text",
      "id": "promo_cta_text",
      "label": "t:settings.promo_cta_text",
      "default": "Get Paid Daily."
    },
    {
      "type": "url",
      "id": "promo_cta_url",
      "label": "t:settings.promo_cta_url"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "t:settings.enable_sticky",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0,
      "unit": "px"
    }
  ]
}
{% endschema %}
