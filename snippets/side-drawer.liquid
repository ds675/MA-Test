{% doc %}
  Side Drawer

  Multi-level navigation drawer with L1/L2/L3 panels, brands, and promo tiles.

  @param {object} section - The parent section object (required)

  @example
  {% render 'side-drawer', section: section %}
{% enddoc %}

{% liquid
  assign drawer_menu = section.settings.drawer_menu | default: section.settings.desktop_menu
  assign drawer_links = linklists[drawer_menu].links
  assign brands_handle = section.settings.brands_handle | default: ''
%}

<side-drawer-component on:keydown="/handleKeydown">
  {%- comment -%} ===== OVERLAY ===== {%- endcomment -%}
  <div
    ref="overlay"
    class="side-drawer__overlay"
    on:click="/handleOverlayClick"
    aria-hidden="true"
  ></div>

  {%- comment -%} ===== DRAWER CONTAINER ===== {%- endcomment -%}
  <div
    ref="drawer"
    class="side-drawer"
    role="dialog"
    aria-modal="true"
    aria-label="{{ 'sections.side_drawer.shop' | t }}"
  >
    {%- comment -%} ---- Header ---- {%- endcomment -%}
    <div class="side-drawer__header">
      <button
        ref="backBtn"
        class="side-drawer__back-btn"
        type="button"
        aria-label="{{ 'sections.side_drawer.back' | t }}"
        on:click="/handleNavigateBack"
        hidden
      >
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M15 18L9 12L15 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ 'sections.side_drawer.back' | t }}
      </button>

      <span ref="headerTitle" class="side-drawer__header-title">
        {{- 'sections.side_drawer.shop' | t -}}
      </span>

      <button
        ref="closeBtn"
        class="side-drawer__close-btn"
        type="button"
        aria-label="{{ 'sections.side_drawer.close' | t }}"
        on:click="/handleCloseClick"
      >
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M6 6L18 18M6 18L18 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%} ---- Panels Container ---- {%- endcomment -%}
    <div ref="panelsContainer" class="side-drawer__panels">

      {%- comment -%} ========== L1 PANEL ========== {%- endcomment -%}
      <div class="side-drawer__panel side-drawer__panel--l1" data-panel-id="l1" data-panel-title="{{ 'sections.side_drawer.shop' | t }}" data-active>

        {%- comment -%} ---- Shop Block ---- {%- endcomment -%}
        <div class="side-drawer__block">
          <span class="side-drawer__block-title">{{ 'sections.side_drawer.shop' | t }}</span>
          {%- for link in drawer_links -%}
            {%- if link.links.size > 0 -%}
              <button
                class="side-drawer__link-row"
                type="button"
                on:click="/handleNavigateToPanel"
                data-panel-target="l2-{{ link.handle }}"
              >
                <span>{{ link.title | escape }}</span>
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M9 6L15 12L9 18" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            {%- else -%}
              <a href="{{ link.url }}" class="side-drawer__link-row">
                <span>{{ link.title | escape }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} ---- Account Block ---- {%- endcomment -%}
        <div class="side-drawer__block">
          <span class="side-drawer__block-title">{{ 'sections.side_drawer.account' | t }}</span>

          {%- if customer -%}
            <a href="{{ routes.account_url }}" class="side-drawer__account-row">
              <span class="side-drawer__account-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M20 21V19C20 16.7909 18.2091 15 16 15H8C5.79086 15 4 16.7909 4 19V21" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="7" r="4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.my_account' | t }}</span>
            </a>
          {%- else -%}
            <a href="{{ routes.account_login_url }}" class="side-drawer__account-row">
              <span class="side-drawer__account-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M20 21V19C20 16.7909 18.2091 15 16 15H8C5.79086 15 4 16.7909 4 19V21" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="7" r="4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.sign_in' | t }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.track_orders_url != blank -%}
            <a href="{{ section.settings.track_orders_url }}" class="side-drawer__account-row">
              <span class="side-drawer__account-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M9 5H7C5.89543 5 5 5.89543 5 7V19C5 20.1046 5.89543 21 7 21H17C18.1046 21 19 20.1046 19 19V7C19 5.89543 18.1046 5 17 5H15" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M9 5C9 3.89543 9.89543 3 11 3H13C14.1046 3 15 3.89543 15 5C15 6.10457 14.1046 7 13 7H11C9.89543 7 9 6.10457 9 5Z" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M9 12L11 14L15 10" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.track_orders' | t }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.reorder_items_url != blank -%}
            <a href="{{ section.settings.reorder_items_url }}" class="side-drawer__account-row">
              <span class="side-drawer__account-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M1 4V10H7" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M3.51 15C4.15839 17.0815 5.54105 18.8528 7.39922 20.0113C9.2574 21.1699 11.4672 21.6405 13.6382 21.3373C15.8093 21.0341 17.7995 19.977 19.2555 18.3518C20.7116 16.7265 21.5422 14.6381 21.5989 12.4503C21.6555 10.2626 20.9345 8.13375 19.5664 6.43432C18.1982 4.73489 16.268 3.57504 14.1143 3.15771C11.9607 2.74038 9.72453 3.09167 7.79736 4.15135L1 8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.reorder_items' | t }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.help_url != blank -%}
            <a href="{{ section.settings.help_url }}" class="side-drawer__account-row">
              <span class="side-drawer__account-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M9.09 9C9.57 7.82 10.78 7 12 7C13.66 7 15 8.34 15 10C15 11.66 12 12.5 12 14" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="17" r="0.5" fill="currentColor" stroke="none"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.help' | t }}</span>
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} ---- Features Block ---- {%- endcomment -%}
        <div class="side-drawer__block">
          <span class="side-drawer__block-title">{{ 'sections.side_drawer.features' | t }}</span>

          {%- if section.settings.home_shopping_list_url != blank -%}
            <a href="{{ section.settings.home_shopping_list_url }}" class="side-drawer__feature-row">
              <span class="side-drawer__feature-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M3 9L12 2L21 9V20C21 20.5304 20.7893 21.0391 20.4142 21.4142C20.0391 21.7893 19.5304 22 19 22H5C4.46957 22 3.96086 21.7893 3.58579 21.4142C3.21071 21.0391 3 20.5304 3 20V9Z" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M9 22V12H15V22" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.home_shopping_list' | t }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.list_manager_url != blank -%}
            <a href="{{ section.settings.list_manager_url }}" class="side-drawer__feature-row">
              <span class="side-drawer__feature-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M8 6H21M8 12H21M8 18H21M3 6H3.01M3 12H3.01M3 18H3.01" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.list_manager' | t }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.egifts_url != blank -%}
            <a href="{{ section.settings.egifts_url }}" class="side-drawer__feature-row">
              <span class="side-drawer__feature-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M20 12V22H4V12" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M22 7H2V12H22V7Z" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 22V7" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 7H7.5C6.83696 7 6.20107 6.73661 5.73223 6.26777C5.26339 5.79893 5 5.16304 5 4.5C5 3.83696 5.26339 3.20107 5.73223 2.73223C6.20107 2.26339 6.83696 2 7.5 2C11 2 12 7 12 7Z" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 7H16.5C17.163 7 17.7989 6.73661 18.2678 6.26777C18.7366 5.79893 19 5.16304 19 4.5C19 3.83696 18.7366 3.20107 18.2678 2.73223C17.7989 2.26339 17.163 2 16.5 2C13 2 12 7 12 7Z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.egifts' | t }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.price_alerts_url != blank -%}
            <a href="{{ section.settings.price_alerts_url }}" class="side-drawer__feature-row">
              <span class="side-drawer__feature-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M18 8C18 6.4087 17.3679 4.88258 16.2426 3.75736C15.1174 2.63214 13.5913 2 12 2C10.4087 2 8.88258 2.63214 7.75736 3.75736C6.63214 4.88258 6 6.4087 6 8C6 15 3 17 3 17H21C21 17 18 15 18 8Z" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M13.73 21C13.5542 21.3031 13.3019 21.5547 12.9982 21.7295C12.6946 21.9044 12.3504 21.9965 12 21.9965C11.6496 21.9965 11.3054 21.9044 11.0018 21.7295C10.6982 21.5547 10.4458 21.3031 10.27 21" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.price_alerts' | t }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.shopbuddy_url != blank -%}
            <a href="{{ section.settings.shopbuddy_url }}" class="side-drawer__feature-row">
              <span class="side-drawer__feature-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M21 15C21 15.5304 20.7893 16.0391 20.4142 16.4142C20.0391 16.7893 19.5304 17 19 17H7L3 21V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H19C19.5304 3 20.0391 3.21071 20.4142 3.58579C20.7893 3.96086 21 4.46957 21 5V15Z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.shopbuddy' | t }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.deals_url != blank -%}
            <a href="{{ section.settings.deals_url }}" class="side-drawer__feature-row">
              <span class="side-drawer__feature-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M20.59 13.41L13.42 20.58C13.2343 20.766 13.0137 20.9135 12.7709 21.0141C12.5281 21.1148 12.2678 21.1666 12.005 21.1666C11.7422 21.1666 11.4819 21.1148 11.2391 21.0141C10.9963 20.9135 10.7757 20.766 10.59 20.58L2 12V2H12L20.59 10.59C20.9625 10.9647 21.1716 11.4716 21.1716 12C21.1716 12.5284 20.9625 13.0353 20.59 13.41Z" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="7" cy="7" r="1.5" fill="currentColor" stroke="none"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.deals' | t }}</span>
            </a>
          {%- endif -%}

          {%- if section.settings.nutri_physical_url != blank -%}
            <a href="{{ section.settings.nutri_physical_url }}" class="side-drawer__feature-row">
              <span class="side-drawer__feature-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M20.84 4.61C20.3292 4.099 19.7228 3.69364 19.0554 3.41708C18.3879 3.14052 17.6725 2.99817 16.95 2.99817C16.2275 2.99817 15.5121 3.14052 14.8446 3.41708C14.1772 3.69364 13.5708 4.099 13.06 4.61L12 5.67L10.94 4.61C9.9083 3.57831 8.50903 2.99871 7.05 2.99871C5.59096 2.99871 4.19169 3.57831 3.16 4.61C2.1283 5.6417 1.54871 7.04097 1.54871 8.5C1.54871 9.95903 2.1283 11.3583 3.16 12.39L4.22 13.45L12 21.23L19.78 13.45L20.84 12.39C21.351 11.8792 21.7563 11.2728 22.0329 10.6053C22.3095 9.93789 22.4518 9.22249 22.4518 8.5C22.4518 7.77751 22.3095 7.0621 22.0329 6.39464C21.7563 5.72718 21.351 5.12075 20.84 4.61Z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ 'sections.side_drawer.nutri_physical' | t }}</span>
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} ---- Footer Block ---- {%- endcomment -%}
        <div class="side-drawer__block side-drawer__footer">
          {%- comment -%} Country selector {%- endcomment -%}
          {%- if localization.available_countries.size > 1 -%}
            <div class="side-drawer__country-selector">
              {%- form 'localization' -%}
                <select name="country_code" onchange="this.form.submit();" aria-label="{{ 'accessibility.country_region' | t }}">
                  {%- for country in localization.available_countries -%}
                    <option
                      value="{{ country.iso_code }}"
                      {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
                    >
                      {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                    </option>
                  {%- endfor -%}
                </select>
                <noscript>
                  <button type="submit">{{ 'actions.apply' | t }}</button>
                </noscript>
              {%- endform -%}
            </div>
          {%- endif -%}

          {%- comment -%} Social icons {%- endcomment -%}
          {% liquid
            assign has_social = false
            if section.settings.social_facebook != blank or section.settings.social_x != blank or section.settings.social_instagram != blank or section.settings.social_tiktok != blank or section.settings.social_youtube != blank
              assign has_social = true
            endif
          %}
          {%- if has_social -%}
            <div class="side-drawer__social-icons">
              {%- if section.settings.social_facebook != blank -%}
                <a href="{{ section.settings.social_facebook }}" class="side-drawer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M18 2H15C13.6739 2 12.4021 2.52678 11.4645 3.46447C10.5268 4.40215 10 5.67392 10 7V10H7V14H10V22H14V14H17L18 10H14V7C14 6.73478 14.1054 6.48043 14.2929 6.29289C14.4804 6.10536 14.7348 6 15 6H18V2Z"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if section.settings.social_x != blank -%}
                <a href="{{ section.settings.social_x }}" class="side-drawer__social-link" aria-label="X" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M4 4L10.5 12.5M20 20L13.5 11.5M10.5 12.5L20 4M10.5 12.5L4 20M13.5 11.5L20 4M13.5 11.5L4 20"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if section.settings.social_instagram != blank -%}
                <a href="{{ section.settings.social_instagram }}" class="side-drawer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                    <path d="M16 11.37C16.1234 12.2022 15.9813 13.0522 15.5938 13.799C15.2063 14.5458 14.5932 15.1514 13.8416 15.5297C13.0901 15.9079 12.2385 16.0396 11.4078 15.9059C10.5771 15.7723 9.80977 15.3801 9.21485 14.7852C8.61993 14.1902 8.22774 13.4229 8.09408 12.5922C7.96042 11.7615 8.09208 10.9099 8.47034 10.1584C8.8486 9.40685 9.4542 8.79374 10.201 8.40624C10.9478 8.01874 11.7978 7.87658 12.63 8C13.4789 8.12588 14.2649 8.52146 14.8717 9.1283C15.4785 9.73515 15.8741 10.5211 16 11.37Z"/>
                    <circle cx="17.5" cy="6.5" r="1.5"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if section.settings.social_tiktok != blank -%}
                <a href="{{ section.settings.social_tiktok }}" class="side-drawer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M9 12C6.79086 12 5 13.7909 5 16C5 18.2091 6.79086 20 9 20C11.2091 20 13 18.2091 13 16V4C13.3333 5.33333 14.6 8 17 8"/>
                  </svg>
                </a>
              {%- endif -%}
              {%- if section.settings.social_youtube != blank -%}
                <a href="{{ section.settings.social_youtube }}" class="side-drawer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M22.54 6.42C22.4212 5.94541 22.1793 5.51057 21.8387 5.15941C21.498 4.80824 21.0708 4.55318 20.6 4.42C18.88 4 12 4 12 4C12 4 5.12 4 3.4 4.46C2.92925 4.59318 2.50198 4.84824 2.16135 5.19941C1.82072 5.55057 1.57879 5.98541 1.46 6.46C1 8.18 1 12 1 12C1 12 1 15.82 1.46 17.54C1.69 18.49 2.44 19.24 3.4 19.54C5.12 20 12 20 12 20C12 20 18.88 20 20.6 19.54C21.56 19.24 22.31 18.49 22.54 17.54C23 15.82 23 12 23 12C23 12 23 8.18 22.54 6.42Z"/>
                    <path d="M9.75 15.02L15.5 12L9.75 8.98V15.02Z" fill="rgb(var(--color-background, 255 255 255))"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ========== L2 PANELS ========== {%- endcomment -%}
      {%- for link in drawer_links -%}
        {%- if link.links.size > 0 -%}
          <div class="side-drawer__panel" data-panel-id="l2-{{ link.handle }}" data-panel-title="{{ link.title | escape }}">
            {%- for child in link.links -%}
              {%- if child.links.size > 0 -%}
                <button
                  class="side-drawer__panel-link"
                  type="button"
                  on:click="/handleNavigateToPanel"
                  data-panel-target="l3-{{ link.handle }}-{{ child.handle }}"
                >
                  <span>{{ child.title | escape }}</span>
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M9 6L15 12L9 18" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              {%- else -%}
                <a href="{{ child.url }}" class="side-drawer__panel-link">
                  <span>{{ child.title | escape }}</span>
                </a>
              {%- endif -%}
            {%- endfor -%}

            {%- comment -%} Promo tiles from menu_panel metaobject {%- endcomment -%}
            {%- if shop.metaobjects.menu_panel != blank -%}
              {%- assign promo_tiles_rendered = false -%}
              {%- for panel in shop.metaobjects.menu_panel.values -%}
                {%- if panel.menu_handle == link.handle -%}
                  {%- unless promo_tiles_rendered -%}
                    <div class="side-drawer__promo-tiles">
                    {%- assign promo_tiles_rendered = true -%}
                  {%- endunless -%}
                  <a href="{{ panel.link.value }}" class="side-drawer__promo-tile">
                    {%- if panel.image.value != blank -%}
                      <img
                        src="{{ panel.image.value | image_url: width: 400 }}"
                        alt="{{ panel.title | escape }}"
                        width="400"
                        height="200"
                        loading="lazy"
                      >
                    {%- endif -%}
                  </a>
                {%- endif -%}
              {%- endfor -%}
              {%- if promo_tiles_rendered -%}
                </div>
              {%- endif -%}
            {%- endif -%}
          </div>

          {%- comment -%} ========== L3 PANELS ========== {%- endcomment -%}
          {%- for child in link.links -%}
            {%- if child.links.size > 0 -%}
              <div class="side-drawer__panel" data-panel-id="l3-{{ link.handle }}-{{ child.handle }}" data-panel-title="{{ child.title | escape }}">
                {%- for grandchild in child.links -%}
                  {%- if grandchild.links.size > 0 -%}
                    {%- comment -%} Accordion group for nested children {%- endcomment -%}
                    {%- assign accordion_id = 'acc-' | append: link.handle | append: '-' | append: child.handle | append: '-' | append: grandchild.handle -%}
                    <div class="side-drawer__accordion">
                      <button
                        class="side-drawer__accordion-trigger"
                        type="button"
                        aria-expanded="false"
                        aria-controls="{{ accordion_id }}"
                        on:click="/handleAccordionToggle"
                      >
                        <span>{{ grandchild.title | escape }}</span>
                        <svg class="side-drawer__accordion-chevron" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                          <path d="M6 9L12 15L18 9" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                      <div id="{{ accordion_id }}" class="side-drawer__accordion-content">
                        {%- for ggchild in grandchild.links -%}
                          <a href="{{ ggchild.url }}">{{ ggchild.title | escape }}</a>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- else -%}
                    <a href="{{ grandchild.url }}" class="side-drawer__panel-link">
                      <span>{{ grandchild.title | escape }}</span>
                    </a>
                  {%- endif -%}
                {%- endfor -%}

                {%- comment -%} Promo tiles from menu_panel metaobject {%- endcomment -%}
                {%- if shop.metaobjects.menu_panel != blank -%}
                  {%- assign l3_promo_rendered = false -%}
                  {%- for panel in shop.metaobjects.menu_panel.values -%}
                    {%- if panel.menu_handle == child.handle -%}
                      {%- unless l3_promo_rendered -%}
                        <div class="side-drawer__promo-tiles">
                        {%- assign l3_promo_rendered = true -%}
                      {%- endunless -%}
                      <a href="{{ panel.link.value }}" class="side-drawer__promo-tile">
                        {%- if panel.image.value != blank -%}
                          <img
                            src="{{ panel.image.value | image_url: width: 400 }}"
                            alt="{{ panel.title | escape }}"
                            width="400"
                            height="200"
                            loading="lazy"
                          >
                        {%- endif -%}
                      </a>
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if l3_promo_rendered -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} ========== BRANDS PANEL ========== {%- endcomment -%}
      {%- if brands_handle != blank and shop.metaobjects.brand != blank -%}
        <div class="side-drawer__panel" data-panel-id="l2-{{ brands_handle }}" data-panel-title="{{ brands_handle | capitalize }}">
          <a href="/collections/{{ brands_handle }}" class="side-drawer__brands-all-link">
            {{ 'sections.side_drawer.shop_all_brands' | t }}
          </a>

          {%- comment -%} Group brands by category {%- endcomment -%}
          {%- assign brand_categories = '' -%}
          {%- for brand in shop.metaobjects.brand.values -%}
            {%- assign cat = brand.category | default: 'Other' -%}
            {%- unless brand_categories contains cat -%}
              {%- if brand_categories != '' -%}
                {%- assign brand_categories = brand_categories | append: '|||' | append: cat -%}
              {%- else -%}
                {%- assign brand_categories = cat -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}

          {%- assign categories_arr = brand_categories | split: '|||' -%}
          {%- for category in categories_arr -%}
            {%- assign brand_acc_id = 'brand-acc-' | append: forloop.index -%}
            <div class="side-drawer__accordion">
              <button
                class="side-drawer__accordion-trigger"
                type="button"
                aria-expanded="false"
                aria-controls="{{ brand_acc_id }}"
                on:click="/handleAccordionToggle"
              >
                <span>{{ category }}</span>
                <svg class="side-drawer__accordion-chevron" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M6 9L12 15L18 9" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div id="{{ brand_acc_id }}" class="side-drawer__accordion-content">
                <div class="side-drawer__brand-grid">
                  {%- for brand in shop.metaobjects.brand.values -%}
                    {%- assign brand_cat = brand.category | default: 'Other' -%}
                    {%- if brand_cat == category -%}
                      <a href="{{ brand.url.value | default: '#' }}" class="side-drawer__brand-item">
                        <span class="side-drawer__brand-logo">
                          {%- if brand.logo != blank -%}
                            <img
                              src="{{ brand.logo.value | image_url: width: 144 }}"
                              alt="{{ brand.title | escape }}"
                              width="72"
                              height="72"
                              loading="lazy"
                            >
                          {%- endif -%}
                        </span>
                        <span class="side-drawer__brand-name">{{ brand.title | escape }}</span>
                      </a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</side-drawer-component>
